    {
      "parameters": {
        "jsCode": "const titleRaw = ($json.title || '').trim();\nconst summaryRaw = ($json.contentSnippet || $json.description || '').trim();\nconst bodyRaw = ($json.content || $json.description || $json.contentSnippet || '').trim();\nif (titleRaw.length < 12 || summaryRaw.length < 40 || !($json.link || $json.feedUrl)) {\n  return [];\n}\nconst haystack = `${titleRaw} ${summaryRaw} ${bodyRaw}`.toLowerCase();\nconst keywords = ['war','conflict','airstrike','military','ceasefire','missile','invasion','troops','shelling','drone','battle','front line','hostage','artillery','offensive','defense ministry'];\nif (!keywords.some(k => haystack.includes(k))) {\n  return [];\n}\nlet region = 'global';\nif (/(ukraine|russia|nato|black sea|poland)/.test(haystack)) region = 'europe';\nelse if (/(gaza|israel|iran|syria|lebanon|yemen)/.test(haystack)) region = 'middle-east';\nelse if (/(sudan|sahel|somalia|ethiopia|congo)/.test(haystack)) region = 'africa';\nelse if (/(taiwan|south china sea|myanmar|korean peninsula)/.test(haystack)) region = 'asia';\nconst normalizedTitle = titleRaw.toLowerCase().replace(/[^a-z0-9 ]+/g, ' ').replace(/\\s+/g, ' ').trim();\nconst base = normalizedTitle || String($json.link || '');\nlet hash = 2166136261;\nfor (let i = 0; i < base.length; i++) {\n  hash ^= base.charCodeAt(i);\n  hash = (hash * 16777619) >>> 0;\n}\nconst eventKey = hash.toString(16).padStart(8, '0') + base.length.toString(16).padStart(8, '0');\nlet confidenceHint = 0.55;\nif (summaryRaw.length > 140) confidenceHint += 0.1;\nif (/(bbc|reuters|associated press|ap news|un news|guardian)/.test(haystack)) confidenceHint += 0.1;\nif (/(unconfirmed|rumou?r|reportedly)/.test(haystack)) confidenceHint -= 0.15;\nconfidenceHint = Math.max(0, Math.min(1, confidenceHint));\nreturn [{ json: { ...$json, title: titleRaw, contentSnippet: summaryRaw, content: bodyRaw, region, event_key: eventKey, confidence_hint: confidenceHint } }];"
      },
