              "value": ""
            },
            {
              "name": "published_at",
              "value": "={{ $json.isoDate || $json.pubDate || $now }}"
            },
            {
              "name": "region",
              "value": "={{ $json.region || 'global' }}"
            },
            {
              "name": "event_key",
              "value": "={{ $json.event_key || '' }}"
            }
          ],
